{
	"name": "@earendil-works/pi-research-tui",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"start": "node --import tsx/esm src/cli.ts",

# Copy this file to .env, then fill in real values before starting the web app.
#
#   cp .env.example .env
#   npm run dev

# Required for SEC filing search and earnings transcripts.
API_NINJAS_KEY=

# Required by SEC EDGAR downloads. Use an app name and contact email.
SEC_USER_AGENT="AgentStanley contact@example.com"

# Set one LLM provider key.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=

# Optional Pi model reference, e.g. openai/gpt-4o.
PI_RESEARCH_MODEL=
